#!/usr/bin/env bash
#
# server — server-manager CLI entrypoint.
#
# A zero-config control panel for deploying & managing web apps on remote
# Linux servers over SSH. Run `server help` for usage.
#
# https://github.com/<your-org>/server-manager   (MIT)

set -Eeuo pipefail

SRVMGR_VERSION="0.1.0"

# ---------------------------------------------------------------------------
# Locate the install root (resolve symlinks so /usr/local/bin/server works).
# ---------------------------------------------------------------------------
_self="${BASH_SOURCE[0]}"
while [[ -L "$_self" ]]; do
  _dir="$(cd -P "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
SRVMGR_BIN_DIR="$(cd -P "$(dirname "$_self")" && pwd)"
SRVMGR_ROOT="$(cd -P "$SRVMGR_BIN_DIR/.." && pwd)"
SRVMGR_LIB="$SRVMGR_ROOT/lib"
SRVMGR_TEMPLATES="$SRVMGR_ROOT/templates"
export SRVMGR_ROOT SRVMGR_LIB SRVMGR_TEMPLATES

# ---------------------------------------------------------------------------
# Source library modules. Order: core first (others depend on it), then the
# rest. Globs tolerate phases that haven't been built yet.
# ---------------------------------------------------------------------------
# shellcheck source=/dev/null
for _f in "$SRVMGR_LIB"/core/json.sh "$SRVMGR_LIB"/core/ui.sh "$SRVMGR_LIB"/core/util.sh \
          "$SRVMGR_LIB"/core/config.sh "$SRVMGR_LIB"/core/notify.sh "$SRVMGR_LIB"/core/ssh.sh \
          "$SRVMGR_LIB"/core/server_registry.sh; do
  [[ -f "$_f" ]] && source "$_f"
done
for _dir in discovery providers deploy commands; do
  for _f in "$SRVMGR_LIB/$_dir"/*.sh; do
    [[ -f "$_f" ]] && source "$_f"
  done
done
unset _f _dir

require_bash
config_init_local

# ---------------------------------------------------------------------------
# Global option parsing. Extract flags that may appear anywhere, leaving the
# command and its positional args in ARGS[].
# ---------------------------------------------------------------------------
OPT_SERVER=""
declare -a ARGS=()

# Switch on the machine-readable event protocol that the desktop UI drives over
# SSH. Events go to fd 3 (wired here to the real stdout) so that internal
# command-substitution capture of fd 1 never corrupts the stream. JSON mode is
# implicitly non-interactive: prompts resolve from the --answers bundle.
_enable_json_mode() {
  export SRVMGR_JSON=1
  export SRVMGR_ASSUME_YES=1
  exec 3>&1
  _UI_EVENT_FD=3
  NO_COLOR=1; ui_init_colors
  # Emit a terminal done event reflecting the final exit status.
  trap '_json_on_exit' EXIT
}

_json_on_exit() {
  local rc=$?
  json_mode || return 0
  local ok=true; (( rc == 0 )) || ok=false
  ui_emit "{\"t\":\"done\",$(json_kv_raw ok "$ok")}"
}

parse_global_args() {
  while (( $# )); do
    case "$1" in
      --server) OPT_SERVER="${2:-}"; shift 2;;
      --server=*) OPT_SERVER="${1#*=}"; shift;;
      -y|--yes) export SRVMGR_ASSUME_YES=1; shift;;
      --json) _enable_json_mode; shift;;
      --answers) SRVMGR_ANSWERS="${2:-}"; export SRVMGR_ANSWERS; shift 2;;
      --plan) export SRVMGR_PHASE=plan; shift;;
      --apply) export SRVMGR_PHASE=apply; shift;;
      --no-color) NO_COLOR=1; ui_init_colors; shift;;
      -h|--help) ARGS=(help); return;;
      -V|--version) ARGS=(version); return;;
      --) shift; while (( $# )); do ARGS+=("$1"); shift; done;;
      *) ARGS+=("$1"); shift;;
    esac
  done
}

# Error trap: report where we failed (helps when a deploy step explodes).
_on_err() {
  local rc=$?
  err "Aborted (exit ${rc})."
  exit "$rc"
}
trap _on_err ERR

usage() {
  cat >&2 <<EOF
${C_BOLD}${C_MAGENTA}server-manager${C_RESET} ${C_GREY}v${SRVMGR_VERSION}${C_RESET} — zero-config deploy & control panel over SSH

${C_BOLD}USAGE${C_RESET}
  server <command> [arguments] [--server <name>] [-y]

${C_BOLD}SITE COMMANDS${C_RESET}
  add [domain] [root]      Wizard: discover, configure and provision a new site
  update <site>            Intelligent zero-downtime deploy (pull, build, migrate, restart)
  update --all [--framework <fw>]  Deploy every matching site
  diff <site>              Preview what a deploy would apply (commits + migrations)
  release <action> <site>  Atomic releases: init | deploy | list | rollback | prune
                           (instant rollback by repointing the 'current' symlink)
  rollback <site> [target] Roll back to a previous deploy (default: previous)
  ssl <site>               Issue or renew the Let's Encrypt certificate
  list                     List managed sites and their health
  import <domain> <root>   Adopt an already-deployed site without deploying
  logs <site> [type]       Tail remote logs (nginx|php|laravel|queue)
  php <site> [args...]     Run artisan/php on the site, or show/switch PHP version
  db import [site] [file]  Import a .sql/.sql.gz dump into a site's database
  db export [site] [file]  Dump a site's database to a local .sql.gz
  scheduler <site> [a]     Laravel scheduler cron: status (default) | on | off
  worker <site> [action]   Workers: status (default) | setup | restart | logs | remove
  cron <site> [action]     Cron jobs: list (default) | add "<sched>" "<cmd>" | remove <n>
  audit [site]             Security audit: findings + one-click fixes
  audit fix <id> [site]    Apply a single audit remediation by id
  audit fixall [site]      Apply every auto-fixable finding in one go
  audit save [site]        Run the audit and record a snapshot
  audit history [site]     Show recorded audit snapshots over time
  metrics [server]         Health snapshot: CPU, memory, disk, load, services
  uptime [site|--all]      HTTP health check (status, response time, up/down)
  config <list|get|set>    Settings: Git author/token, TLS email, defaults
  notify <action> …        Notifications: status | set slack|telegram … | test | off
  git <action> <site> …    Git: log|status|branches|checkout|fetch|pull|
                           branch <name>|tag <name>|pr <title>|push [--deploy]|
                           deploy [branch]  (push --deploy runs the deploy)

${C_BOLD}SERVER COMMANDS${C_RESET}
  connect <name> user@host Register a server (probes SSH + sudo). Add -p to
                           authenticate by password instead of an SSH key.
  use <name>               Set the default server
  servers                  List registered servers

${C_BOLD}GLOBAL OPTIONS${C_RESET}
  --server <name>          Target a specific server (overrides the default)
  -y, --yes                Assume "yes" for all confirmations (non-interactive)
  --no-color               Disable coloured output
  -h, --help               Show this help
  -V, --version            Show version

Sites and deploy history live on each server under ${REMOTE_ETC}/.
You never edit config files by hand — the wizard manages everything.
EOF
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
main() {
  parse_global_args "$@"
  local cmd="${ARGS[0]:-help}"
  # Restore the remaining args into $@ (bash-3.2-safe for empty arrays).
  set -- ${ARGS[@]+"${ARGS[@]}"}
  if [[ $# -gt 0 ]]; then shift; fi   # drop the command itself

  case "$cmd" in
    help|"")        usage;;
    version)
      if json_mode; then
        ui_emit "{\"t\":\"version\",$(json_kv_string contract "$SRVMGR_JSON_CONTRACT"),$(json_kv_string version "$SRVMGR_VERSION")}"
      else
        printf 'server-manager %s\n' "$SRVMGR_VERSION"
      fi;;

    connect)        cmd_server_connect "$@";;
    use)            cmd_server_use "$@";;
    servers)        cmd_server_servers "$@";;

    add)            _require_cmd_impl cmd_add "$cmd";      cmd_add "$@";;
    update)         _require_cmd_impl cmd_update "$cmd";   cmd_update "$@";;
    diff)           _require_cmd_impl cmd_diff "$cmd";     cmd_diff "$@";;
    release)        _require_cmd_impl cmd_release "$cmd";  cmd_release "$@";;
    rollback)       _require_cmd_impl cmd_rollback "$cmd"; cmd_rollback "$@";;
    ssl)            _require_cmd_impl cmd_ssl "$cmd";       cmd_ssl "$@";;
    list)           _require_cmd_impl cmd_list "$cmd";      cmd_list "$@";;
    import)         _require_cmd_impl cmd_import "$cmd";    cmd_import "$@";;
    logs)           _require_cmd_impl cmd_logs "$cmd";      cmd_logs "$@";;
    php)            _require_cmd_impl cmd_php "$cmd";        cmd_php "$@";;
    db)             _require_cmd_impl cmd_db "$cmd";         cmd_db "$@";;
    scheduler)      _require_cmd_impl cmd_scheduler "$cmd";  cmd_scheduler "$@";;
    worker|workers) _require_cmd_impl cmd_worker "$cmd";     cmd_worker "$@";;
    cron)           _require_cmd_impl cmd_cron "$cmd";       cmd_cron "$@";;
    audit)          _require_cmd_impl cmd_audit "$cmd";      cmd_audit "$@";;
    metrics|health) _require_cmd_impl cmd_metrics "$cmd";    cmd_metrics "$@";;
    uptime)         _require_cmd_impl cmd_uptime "$cmd";     cmd_uptime "$@";;
    git)            _require_cmd_impl cmd_git "$cmd";        cmd_git "$@";;
    notify)         _require_cmd_impl cmd_notify "$cmd";     cmd_notify "$@";;
    config)         _require_cmd_impl cmd_config "$cmd";     cmd_config "$@";;

    *)
      err "Unknown command '${cmd}'."
      say "Run 'server help' for usage."
      exit 2;;
  esac
}

# Guard for commands whose modules may not be present yet during development.
_require_cmd_impl() {
  declare -F "$1" >/dev/null 2>&1 || die "Command '$2' is not available in this build."
}

main "$@"
